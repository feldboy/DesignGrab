{
    "manifest_version": 3,
    "name": "DesignGrab",
    "key": "",
    "description": "Extract any website's design in seconds. Colors, fonts, CSS, SVGs, Lottie, and production-ready code.",
    "version": "1.0.3",
    "icons": {
        "16": "assets/icons/icon-16.png",
        "32": "assets/icons/icon-32.png",
        "48": "assets/icons/icon-48.png",
        "128": "assets/icons/icon-128.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads",
        "sidePanel",
        "identity"
    ],
    "oauth2": {
        "client_id": "783180663354-idjnv92nubl3e1dbe5ufm7jq8ll6m1pd.apps.googleusercontent.com",
        "scopes": [
            "openid",
            "email",
            "profile"
        ]
    },
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "side_panel": {
        "default_path": "panel/index.html"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon-16.png",
            "32": "assets/icons/icon-32.png"
        }
    },
    "commands": {
        "toggle-inspector": {
            "suggested_key": {
                "default": "Ctrl+Shift+G",
                "mac": "Command+Shift+G"
            },
            "description": "Toggle DesignGrab inspector"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}