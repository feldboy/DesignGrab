---
// This is the Footer component
---
<footer class="py-12 px-6 border-t border-white/5 bg-black/20">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex items-center gap-2 opacity-80">
      <div class="w-6 h-6 rounded flex items-center justify-center" style="background-color: #2e0bda;">
        <svg width="12" height="12" viewBox="0 0 20 20" fill="none">
          <rect width="20" height="20" rx="5" fill="none" />
          <path d="M6 7L10 10L6 13" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <span class="text-sm font-bold tracking-tight text-white">DesignGrab</span>
    </div>
    <div class="flex gap-8">
      <a class="text-xs font-medium text-slate-500 hover:text-white transition-colors" href="/privacy">Privacy Policy</a>
      <a class="text-xs font-medium text-slate-500 hover:text-white transition-colors" href="mailto:support@designgrab.app">Contact</a>
    </div>
    <p class="text-xs text-slate-600 font-medium tracking-wide">
      © 2026 DesignGrab. All rights reserved.
    </p>
  </div>
</footer>
