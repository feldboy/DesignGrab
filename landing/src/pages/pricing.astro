---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Pricing — DesignGrab" description="Simple, transparent pricing. Start for free. Upgrade when your design needs grow.">
  <div class="relative min-h-screen flex flex-col overflow-x-hidden" style="background-color: #0f0f1a;">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[800px] pointer-events-none" style="background: radial-gradient(circle at center, rgba(46, 11, 218, 0.15) 0%, transparent 70%);"></div>
    
    <Nav />

    <main class="flex-grow">
      <!-- Pricing Header -->
      <section class="pt-24 pb-12 px-6 max-w-4xl mx-auto text-center relative z-10">
        <h1 class="text-5xl md:text-7xl font-black text-white tracking-tight mb-6 mt-12">
          Simple, transparent pricing.
        </h1>
        <p class="text-xl text-slate-400">
          Start for free. Upgrade when your design needs grow.
        </p>
        
        <!-- Toggle -->
        <div class="mt-12 inline-flex items-center gap-2 p-1 rounded-full border border-white/10" style="background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(12px);">
          <button class="px-6 py-2 rounded-full text-sm font-semibold text-white bg-white/10 shadow-sm transition-all">Monthly</button>
          <button class="px-6 py-2 rounded-full text-sm font-medium text-slate-400 hover:text-white transition-all">Yearly <span class="text-indigo-400 text-[10px] ml-1 uppercase tracking-wider font-bold">Save 20%</span></button>
        </div>
      </section>

      <!-- Pricing Cards -->
      <section class="pb-24 px-6 max-w-6xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
          
          <!-- Free Tier -->
          <div class="p-8 rounded-3xl border border-white/10 flex flex-col items-start relative overflow-hidden transition-all hover:border-white/20" style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(12px);">
            <div class="mb-8 w-full border-b border-white/10 pb-8">
              <h3 class="text-2xl font-bold text-white mb-2">Free</h3>
              <p class="text-sm text-slate-400 mb-6 min-h-[40px]">Perfect for evaluating the tool.</p>
              <div class="flex items-baseline gap-1">
                <span class="text-5xl font-black text-white">$0</span>
              </div>
              <div class="text-sm text-slate-500 mt-1">forever</div>
            </div>
            <ul class="space-y-4 mb-10 w-full flex-1">
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> Basic inspector
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> 15 asset downloads / mo
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> 5 code exports / mo
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> Local library
              </li>
            </ul>
            <a href="https://chrome.google.com/webstore/detail/designgrab/PLACEHOLDER_ID" target="_blank" rel="noopener" class="mt-auto w-full py-4 text-center bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl font-bold transition-all flex items-center justify-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Install Extension
            </a>
          <div class="p-8 rounded-3xl border-2 border-indigo-500/50 flex flex-col items-start relative overflow-hidden md:-mt-8 md:mb-8 shadow-[0_0_50px_rgba(99,102,241,0.15)]" style="background: rgba(99, 102, 241, 0.05); backdrop-filter: blur(12px);">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 bg-indigo-500 text-white text-[10px] font-bold uppercase tracking-widest px-4 py-1.5 rounded-b-xl shadow-lg">
              Most Popular
            </div>
            <div class="mb-8 w-full border-b border-indigo-500/20 pb-8 mt-4">
              <h3 class="text-2xl font-bold text-white mb-2">Pro</h3>
              <p class="text-sm text-slate-400 mb-6 min-h-[40px]">For professionals and teams.</p>
              <div class="flex items-baseline gap-1">
                <span class="text-5xl font-black text-white">$12</span>
                <span class="text-slate-500 font-medium">/mo</span>
              </div>
              <div class="text-sm text-slate-500 mt-1">billed monthly</div>
            </div>
            <ul class="space-y-4 mb-10 w-full flex-1">
              <li class="flex items-start gap-3 text-white font-medium">
                <span class="text-indigo-400 mt-0.5">✓</span> Everything in Free
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> 2,000 asset downloads / mo
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> Unlimited code exports
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> 50 AI code exports / mo
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> Figma export
              </li>
            </ul>
            <a href="https://chrome.google.com/webstore/detail/designgrab/PLACEHOLDER_ID" target="_blank" rel="noopener" class="mt-auto w-full py-4 text-center bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-500 hover:to-indigo-400 text-white rounded-xl font-bold transition-all shadow-lg shadow-indigo-500/25 border-0 flex items-center justify-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Install Extension
            </a>
          </div>

          <!-- Lifetime Tier -->
          <div class="p-8 rounded-3xl border border-white/10 flex flex-col items-start relative overflow-hidden transition-all hover:border-white/20" style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(12px);">
            <div class="mb-8 w-full border-b border-white/10 pb-8">
              <h3 class="text-2xl font-bold text-white mb-2">Lifetime</h3>
              <p class="text-sm text-slate-400 mb-6 min-h-[40px]">Pay once, own it forever.</p>
              <div class="flex items-baseline gap-1">
                <span class="text-5xl font-black text-white">$99</span>
              </div>
              <div class="text-sm text-slate-500 mt-1">one-time payment</div>
            </div>
            <ul class="space-y-4 mb-10 w-full flex-1">
              <li class="flex items-start gap-3 text-white font-medium">
                <span class="text-indigo-400 mt-0.5">✓</span> Everything in Pro forever
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> Free future updates
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> Early access to features
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-indigo-400 mt-0.5">✓</span> Priority support
              </li>
            </ul>
            <a href="https://chrome.google.com/webstore/detail/designgrab/PLACEHOLDER_ID" target="_blank" rel="noopener" class="mt-auto w-full py-4 text-center bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl font-bold transition-all flex items-center justify-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Install Extension
            </a>
          </div>

        </div>
      </section>

      <!-- FAQ Section -->
      <section id="faq" class="py-24 px-6 max-w-3xl mx-auto border-t border-white/5 relative z-10">
        <div class="flex flex-col items-center gap-4 mb-16 text-center">
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight">Frequently Asked Questions</h2>
        </div>
        
        <div class="space-y-4">
          <details class="group bg-white/5 border border-white/10 rounded-2xl [&_summary::-webkit-details-marker]:hidden overflow-hidden transition-all hover:border-white/20">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-white">
              <span class="text-lg">Is it really free?</span>
              <span class="transition group-open:rotate-180 text-indigo-400">
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-slate-400 text-base leading-relaxed">
              Yes. The free plan gives you full access to the inspector, color/font/layout analysis, and a generous monthly quota of downloads and code exports. No credit card required.
            </div>
          </details>
          
          <details class="group bg-white/5 border border-white/10 rounded-2xl [&_summary::-webkit-details-marker]:hidden overflow-hidden transition-all hover:border-white/20">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-white">
              <span class="text-lg">How does the AI export work?</span>
              <span class="transition group-open:rotate-180 text-indigo-400">
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-slate-400 text-base leading-relaxed">
              DesignGrab captures the full design context of a pinned element — HTML, CSS, colors, fonts, layout structure — and sends it to Claude (Anthropic's AI) to generate a production-ready React TSX, Vue SFC, or Figma-compatible SVG component.
            </div>
          </details>

          <details class="group bg-white/5 border border-white/10 rounded-2xl [&_summary::-webkit-details-marker]:hidden overflow-hidden transition-all hover:border-white/20">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-white">
              <span class="text-lg">Is my data private?</span>
              <span class="transition group-open:rotate-180 text-indigo-400">
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-slate-400 text-base leading-relaxed">
              Absolutely. DesignGrab runs entirely in your browser. Your design data, saved library, and API keys are stored locally in Chrome storage. Nothing is sent to our servers.
            </div>
          </details>

          <details class="group bg-white/5 border border-white/10 rounded-2xl [&_summary::-webkit-details-marker]:hidden overflow-hidden transition-all hover:border-white/20">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-white">
              <span class="text-lg">Can I cancel anytime?</span>
              <span class="transition group-open:rotate-180 text-indigo-400">
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-slate-400 text-base leading-relaxed">
              Our Pro plan is billed monthly and you can cancel your subscription at any time with one click. You'll continue to have access until the end of your billing cycle.
            </div>
          </details>
        </div>
      </section>
    </main>

    <!-- Sign In CTA -->
    <section id="signin" class="py-24 px-6 max-w-3xl mx-auto text-center border-t border-white/5 w-full relative z-10">
      <div class="p-12 rounded-3xl border border-white/10 relative overflow-hidden" style="background: rgba(255,255,255,0.03);">
        <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/10 to-transparent pointer-events-none"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">Ready to start?</h2>
          <p class="text-slate-400 mb-8 max-w-md mx-auto">Install the Chrome extension to start using DesignGrab for free.</p>
          <a href="https://chrome.google.com/webstore/detail/designgrab/PLACEHOLDER_ID" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 bg-white text-gray-800 hover:bg-gray-100 rounded-xl px-8 py-4 font-bold transition-all shadow-lg border-0 text-lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Install Chrome Extension
          </a>
          <p class="text-xs text-slate-500 mt-4">Free to use. No credit card required.</p>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Base>
