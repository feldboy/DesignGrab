---
import Base from '../layouts/Base.astro';
import FeatureShowcase from '../components/FeatureShowcase.astro';
---

<Base>
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <svg width="28" height="28" viewBox="0 0 20 20" fill="none">
          <rect width="20" height="20" rx="5" fill="url(#g)" />
          <path d="M6 7L10 10L6 13" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          <line x1="11" y1="13" x2="15" y2="13" stroke="#fff" stroke-width="1.5" stroke-linecap="round" />
          <defs><linearGradient id="g" x1="0" y1="0" x2="20" y2="20"><stop stop-color="#6366f1" /><stop offset="1" stop-color="#8b5cf6" /></linearGradient></defs>
        </svg>
        <span>DesignGrab</span>
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
        <a href="#waitlist" class="nav-cta">Get Early Access</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="container">
      <div class="hero-badge">Chrome Extension · Figma Export</div>
      <h1 class="hero-title">
        Export any website<br />
        <span class="gradient-text">directly into Figma</span>
      </h1>
      <p class="hero-sub">
        Click any element. Grab colors, fonts, and CSS. AI generates Figma-ready
        components you can paste straight into your design files — in seconds.
      </p>
      <div class="hero-actions">
        <a href="#waitlist" class="btn btn-primary btn-lg">
          Join the Waitlist
        </a>
        <a href="#features" class="btn btn-ghost btn-lg">
          See Features
        </a>
      </div>
      <div class="hero-demo">
        <div class="demo-window">
          <div class="demo-bar">
            <span class="demo-dot" style="background:#f87171"></span>
            <span class="demo-dot" style="background:#fbbf24"></span>
            <span class="demo-dot" style="background:#4ade80"></span>
            <span class="demo-bar-title">DesignGrab — Side Panel</span>
          </div>
          <div class="demo-body">
            <div class="demo-tabs">
              <span class="demo-tab active">Figma Export</span>
              <span class="demo-tab">Inspector</span>
              <span class="demo-tab">Colors</span>
              <span class="demo-tab">Fonts</span>
              <span class="demo-tab">Code</span>
            </div>
            <div class="demo-content">
              <div class="demo-element-header">
                <code>&lt;div&gt;.hero-card#main</code>
                <span class="demo-dims figma-badge">→ Figma</span>
              </div>
              <div class="demo-props">
                <div class="demo-prop"><span>background</span><span><span class="demo-swatch" style="background:#1a1a2e"></span>#1a1a2e</span></div>
                <div class="demo-prop"><span>border-radius</span><span>12px</span></div>
                <div class="demo-prop"><span>padding</span><span>24px</span></div>
                <div class="demo-prop"><span>font-family</span><span>Inter</span></div>
                <div class="demo-prop"><span>color</span><span><span class="demo-swatch" style="background:#e4e4e7"></span>#e4e4e7</span></div>
                <div class="demo-prop"><span>box-shadow</span><span>0 4px 24px rgba(0,0,0,.3)</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Everything you need to<br /><span class="gradient-text">reverse-engineer any design</span></h2>
        <p class="section-sub">Figma export at its core — plus eight more powerful tools in one lightweight Chrome extension.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card featured figma-featured">
          <div class="feature-icon">🎯</div>
          <h3>Figma Export <span class="feature-badge">Core Feature</span></h3>
          <p>AI-powered SVG generation that you can paste directly into Figma. Preserves colors, typography, and layout — bridging the web and your design files instantly.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔍</div>
          <h3>Element Inspector</h3>
          <p>Click any element to see its full computed styles — colors, fonts, spacing, borders, shadows. Copy any value instantly.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎨</div>
          <h3>Color Extraction</h3>
          <p>Auto-detect every color on a page. Grouped by role — backgrounds, text, accents. Accessibility contrast checks included.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔤</div>
          <h3>Font Analysis</h3>
          <p>Detect all font families, weights, and sources. See the complete typography scale with usage breakdown.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⟨/⟩</div>
          <h3>AI Code Export</h3>
          <p>Export any element as clean HTML+CSS, Tailwind, or AI-generated React TSX and Vue SFC components. Production-ready.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🖼</div>
          <h3>Asset Extraction</h3>
          <p>Find every image, SVG, video, and Lottie animation on a page. Download or copy SVG code in one click.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⊞</div>
          <h3>Layout Analysis</h3>
          <p>Understand any page's structure. See the DOM tree, flexbox/grid properties, and structural HTML at a glance.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">✦</div>
          <h3>Animation Capture</h3>
          <p>Extract CSS keyframe animations, transitions, and Lottie files with full timing and easing details.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">♡</div>
          <h3>Design Library</h3>
          <p>Save colors, fonts, SVGs, and images from any site into your personal library. Build your design system as you browse.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Showcases -->
  <section class="showcases-section">
    <FeatureShowcase
      heading="Inspect any element instantly"
      desc="Hover over any element on any website. See its full computed styles — dimensions, colors, typography, spacing, shadows — all in a beautiful overlay."
      bullets={[
        "Box model visualization (margin, padding, border)",
        "Click-to-copy any CSS value",
        "Pin elements for deeper analysis",
        "Works on any website, any framework",
      ]}
      badge="Core Feature"
    >
      <div class="demo-mock demo-inspector">
        <div class="di-page">
          <div class="di-element di-el-1"></div>
          <div class="di-element di-el-2">
            <div class="di-cursor"></div>
            <div class="di-overlay">
              <div class="di-margin-box"></div>
              <div class="di-padding-box"></div>
              <div class="di-content-box"></div>
            </div>
            <div class="di-tooltip">
              <div class="di-tooltip-row"><span>width</span><span>420px</span></div>
              <div class="di-tooltip-row"><span>padding</span><span>24px</span></div>
              <div class="di-tooltip-row"><span>border-radius</span><span>12px</span></div>
              <div class="di-tooltip-row"><span>font-family</span><span>Inter</span></div>
            </div>
          </div>
          <div class="di-element di-el-3"></div>
        </div>
      </div>
    </FeatureShowcase>

    <FeatureShowcase
      heading="Extract colors & fonts automatically"
      desc="Scan an entire page in one click. Get the complete color palette grouped by role, and every font family with usage breakdown and typography scale."
      bullets={[
        "Colors grouped: primary, text, background, accent",
        "WCAG contrast accessibility audit",
        "Font weights, sources, and load URLs",
        "One-click copy as HEX, RGB, or HSL",
      ]}
      reverse={true}
    >
      <div class="demo-mock demo-colors">
        <div class="dc-header">
          <span class="dc-tab dc-tab-active">Colors</span>
          <span class="dc-tab">Fonts</span>
        </div>
        <div class="dc-palette">
          <div class="dc-swatch-row">
            <div class="dc-swatch" style="background:#6366f1"></div>
            <div class="dc-info"><span class="dc-hex">#6366f1</span><span class="dc-role">Primary</span></div>
            <div class="dc-count">142×</div>
          </div>
          <div class="dc-swatch-row">
            <div class="dc-swatch" style="background:#1a1a2e"></div>
            <div class="dc-info"><span class="dc-hex">#1a1a2e</span><span class="dc-role">Text</span></div>
            <div class="dc-count">89×</div>
          </div>
          <div class="dc-swatch-row">
            <div class="dc-swatch" style="background:#f8f9fa"></div>
            <div class="dc-info"><span class="dc-hex">#f8f9fa</span><span class="dc-role">Background</span></div>
            <div class="dc-count">67×</div>
          </div>
          <div class="dc-swatch-row">
            <div class="dc-swatch" style="background:#4ade80"></div>
            <div class="dc-info"><span class="dc-hex">#4ade80</span><span class="dc-role">Accent</span></div>
            <div class="dc-count">23×</div>
          </div>
          <div class="dc-swatch-row dc-swatch-pulse">
            <div class="dc-swatch" style="background:#e94560"></div>
            <div class="dc-info"><span class="dc-hex">#e94560</span><span class="dc-role">CTA</span></div>
            <div class="dc-count">11×</div>
          </div>
        </div>
        <div class="dc-contrast">
          <span class="dc-contrast-label">WCAG AA</span>
          <span class="dc-contrast-pass">✓ Pass 7.4:1</span>
        </div>
      </div>
    </FeatureShowcase>

    <FeatureShowcase
      heading="AI-powered code export"
      desc="Select any section and export it as a production-ready React TSX or Vue SFC component. Claude AI generates clean, typed, responsive code with Tailwind CSS."
      bullets={[
        "React TSX with TypeScript props",
        "Vue 3 SFC with Composition API",
        "Tailwind CSS — no inline styles",
        "Accessible, responsive, production-ready",
      ]}
      badge="Pro Feature"
    >
      <div class="demo-mock demo-ai">
        <div class="da-header">
          <span class="da-tab da-tab-active">React TSX</span>
          <span class="da-tab">Vue SFC</span>
          <span class="da-tab">HTML+CSS</span>
        </div>
        <div class="da-code">
          <div class="da-line"><span class="da-kw">export default</span> <span class="da-fn">function</span> <span class="da-name">HeroCard</span><span class="da-p">(</span><span class="da-prop">{ title, subtitle }</span><span class="da-p">)</span> <span class="da-p">{</span></div>
          <div class="da-line da-indent"><span class="da-kw">return</span> <span class="da-p">(</span></div>
          <div class="da-line da-indent-2"><span class="da-tag">&lt;section</span> <span class="da-attr">className</span><span class="da-p">=</span><span class="da-str">"flex flex-col items-center gap-8 py-20"</span><span class="da-tag">&gt;</span></div>
          <div class="da-line da-indent-3"><span class="da-tag">&lt;h1</span> <span class="da-attr">className</span><span class="da-p">=</span><span class="da-str">"text-5xl font-bold"</span><span class="da-tag">&gt;</span></div>
          <div class="da-line da-indent-4 da-typing"><span class="da-p">{title}</span></div>
          <div class="da-line da-indent-3"><span class="da-tag">&lt;/h1&gt;</span></div>
          <div class="da-line da-indent-3"><span class="da-tag">&lt;p</span> <span class="da-attr">className</span><span class="da-p">=</span><span class="da-str">"text-lg text-gray-400"</span><span class="da-tag">&gt;</span></div>
          <div class="da-line da-indent-4"><span class="da-p">{subtitle}</span></div>
          <div class="da-line da-indent-3"><span class="da-tag">&lt;/p&gt;</span></div>
          <div class="da-line da-indent-2"><span class="da-tag">&lt;/section&gt;</span></div>
          <div class="da-line da-indent"><span class="da-p">)</span></div>
          <div class="da-line"><span class="da-p">}</span></div>
        </div>
        <div class="da-status">
          <span class="da-ai-badge">⚡ Claude AI</span>
          <span class="da-copy">Copy Component</span>
        </div>
      </div>
    </FeatureShowcase>

    <FeatureShowcase
      heading="Layout DNA — understand structure, not just styles"
      desc="Other tools show you CSS values. DesignGrab shows you how the layout actually works — Flexbox directions, Grid templates, alignment, and gaps. Reverse-engineer any layout."
      bullets={[
        "Flexbox: direction, align, justify, gap",
        "Grid: template columns, rows, areas",
        "Structural HTML with layout classes",
        "Export as Tailwind layout utilities",
      ]}
      badge="Differentiator"
      reverse={true}
    >
      <div class="demo-mock demo-layout">
        <div class="dl-tree">
          <div class="dl-node dl-root">
            <span class="dl-tag">flex</span>
            <span class="dl-dir">column</span>
            <span class="dl-gap">gap: 32px</span>
          </div>
          <div class="dl-children">
            <div class="dl-branch"></div>
            <div class="dl-node dl-child">
              <span class="dl-tag">flex</span>
              <span class="dl-dir">row</span>
              <span class="dl-gap">gap: 16px</span>
            </div>
            <div class="dl-grandchildren">
              <div class="dl-branch"></div>
              <div class="dl-node dl-leaf"><span class="dl-tag">img</span><span class="dl-size">w: 50%</span></div>
              <div class="dl-branch"></div>
              <div class="dl-node dl-leaf"><span class="dl-tag">flex</span><span class="dl-dir">col</span></div>
            </div>
            <div class="dl-branch"></div>
            <div class="dl-node dl-child">
              <span class="dl-tag">grid</span>
              <span class="dl-cols">1fr 1fr 1fr</span>
              <span class="dl-gap">gap: 24px</span>
            </div>
          </div>
        </div>
        <div class="dl-output">
          <code>flex flex-col items-center gap-8</code>
        </div>
      </div>
    </FeatureShowcase>
  </section>
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Three steps. Zero friction.</h2>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Inspect</h3>
          <p>Open the side panel and click any element on the page. Or press <kbd>Cmd+Shift+G</kbd>.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Extract</h3>
          <p>See every design detail — colors, fonts, spacing, CSS. Grab assets, SVGs, and animations.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Export to Figma</h3>
          <p>Paste AI-generated components directly into Figma. Or export React, Vue, or Tailwind — production-ready code in one click.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Simple, fair pricing</h2>
        <p class="section-sub">Start free. Upgrade when you need more.</p>
      </div>
      <div class="pricing-grid">
        <div class="price-card">
          <div class="price-name">Free</div>
          <div class="price-amount">$0</div>
          <div class="price-period">forever</div>
          <ul class="price-features">
            <li>Inspector, colors, fonts, layout</li>
            <li>15 asset downloads / month</li>
            <li>5 code exports / month</li>
            <li>Local design library</li>
          </ul>
          <a href="#waitlist" class="btn btn-ghost">Get Started</a>
        </div>
        <div class="price-card popular">
          <div class="price-badge">Most Popular</div>
          <div class="price-name">Pro</div>
          <div class="price-amount">$12<span>/mo</span></div>
          <div class="price-period">billed monthly</div>
          <ul class="price-features">
            <li>Everything in Free</li>
            <li>2,000 downloads / month</li>
            <li>Unlimited code exports</li>
            <li>50 AI exports / month</li>
            <li>Figma export</li>
            <li>Priority support</li>
          </ul>
          <a href="#waitlist" class="btn btn-primary">Join Waitlist</a>
        </div>
        <div class="price-card">
          <div class="price-name">Lifetime</div>
          <div class="price-amount">$99</div>
          <div class="price-period">one-time payment</div>
          <ul class="price-features">
            <li>Everything in Pro</li>
            <li>Pay once, use forever</li>
            <li>All future updates</li>
            <li>Early access to new features</li>
          </ul>
          <a href="#waitlist" class="btn btn-ghost">Join Waitlist</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Frequently asked questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Is it really free?</summary>
          <p>Yes. The free plan gives you full access to the inspector, color/font/layout analysis, and a generous monthly quota of downloads and code exports. No credit card required.</p>
        </details>
        <details class="faq-item">
          <summary>How does the AI export work?</summary>
          <p>DesignGrab captures the full design context of a pinned element — HTML, CSS, colors, fonts, layout structure — and sends it to Claude (Anthropic's AI) to generate a production-ready React TSX, Vue SFC, or Figma-compatible SVG component.</p>
        </details>
        <details class="faq-item">
          <summary>Do I need my own API key?</summary>
          <p>For AI exports, yes — you provide your own Anthropic API key in Settings. This means your usage is billed directly by Anthropic at their rates, and your data never touches our servers.</p>
        </details>
        <details class="faq-item">
          <summary>Does it work on any website?</summary>
          <p>DesignGrab works on any publicly accessible website. It reads the live DOM and computed styles, so it works regardless of what framework or CSS methodology the site uses.</p>
        </details>
        <details class="faq-item">
          <summary>Is my data private?</summary>
          <p>Absolutely. DesignGrab runs entirely in your browser. Your design data, saved library, and API keys are stored locally in Chrome storage. Nothing is sent to our servers.</p>
        </details>
        <details class="faq-item">
          <summary>Can I cancel anytime?</summary>
          <p>Yes. Pro subscriptions can be cancelled anytime from your account. You keep access until the end of your billing period. Lifetime is a one-time purchase with no recurring charges.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Waitlist -->
  <section id="waitlist" class="section">
    <div class="container">
      <div class="waitlist-box">
        <h2 class="section-title">Get early access</h2>
        <p class="section-sub" style="margin-bottom:24px;">Be the first to know when DesignGrab launches on the Chrome Web Store.</p>
        <form class="waitlist-form" id="waitlist-form">
          <input type="email" name="email" placeholder="you@email.com" required class="waitlist-input" />
          <button type="submit" class="btn btn-primary">Join Waitlist</button>
        </form>
        <p class="waitlist-note" id="waitlist-msg">No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-left">
        <span class="footer-brand">DesignGrab</span>
        <span class="footer-copy">&copy; 2026 DesignGrab. All rights reserved.</span>
      </div>
      <div class="footer-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="mailto:support@designgrab.app">Contact</a>
      </div>
    </div>
  </footer>
</Base>

<style>
  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(6, 6, 14, 0.8);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 16px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 14px;
    color: var(--text-secondary);
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    padding: 7px 16px;
    border-radius: 8px;
    background: var(--accent);
    color: white !important;
    font-weight: 600;
    font-size: 13px;
    transition: background 0.15s;
  }
  .nav-cta:hover { background: #4f46e5; }

  /* Container */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 22px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 14px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font);
  }
  .btn-primary {
    background: var(--gradient);
    color: white;
    box-shadow: 0 2px 12px rgba(99, 102, 241, 0.3);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(99, 102, 241, 0.4); }
  .btn-ghost {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-strong);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.04); color: var(--text); }
  .btn-lg { padding: 14px 32px; font-size: 15px; border-radius: 12px; }

  /* Gradient text */
  .gradient-text {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Hero */
  .hero {
    position: relative;
    padding: 140px 0 60px;
    text-align: center;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 100px;
    background: var(--accent-light);
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 24px;
    border: 1px solid rgba(99, 102, 241, 0.2);
  }
  .hero-title {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }
  .hero-sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 60px;
  }

  /* Demo Window */
